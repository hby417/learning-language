# =============================================================
# LearnLanguage — Ortam Değişkenleri Şablonu
# =============================================================
# Bu dosyayı kopyalayın ve ".env" olarak kaydedin, sonra
# gerçek değerlerle doldurun:
#
#   cp .env.example .env
#
# UYARI: .env dosyasını ASLA Git'e eklemeyin!
#        .gitignore dosyanızda ".env" satırının olduğundan emin olun.
# =============================================================


# -------------------------------------------------------------
# PostgreSQL Veritabanı
# -------------------------------------------------------------
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=


# -------------------------------------------------------------
# Backend — Firebase Admin SDK
# Firebase Konsol -> Proje Ayarlari -> Hizmet Hesaplari
#   -> "Yeni ozel anahtar olustur" -> JSON dosyasini indirin
# -------------------------------------------------------------
FIREBASE_PROJECT_ID=

# Firebase Service Account JSON dosyasinin HOST makinedeki tam yolu
# Windows ornegi:   C:/Users/KullaniciAdi/secrets/firebase-adminsdk.json
# Linux/Mac ornegi: /home/user/secrets/firebase-adminsdk.json
FIREBASE_SERVICE_ACCOUNT_PATH=


# -------------------------------------------------------------
# Backend — Gemini API
# Google AI Studio -> https://aistudio.google.com/app/apikey
# -------------------------------------------------------------
GEMINI_API_KEY=


# -------------------------------------------------------------
# Web UI — Firebase (Tarayici tarafli yapilandirma)
# Firebase Konsol -> Proje Ayarlari -> Genel -> Web Uygulamaniz
# -------------------------------------------------------------
VITE_API_BASE_URL=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=


# -------------------------------------------------------------
# Port Ayarlari (Istege bagli — varsayilanlar yeterli)
# -------------------------------------------------------------
BACKEND_PORT=8080
WEB_PORT=80


# -------------------------------------------------------------
# pgAdmin (Opsiyonel — sadece --profile tools ile acilir)
# -------------------------------------------------------------
PGADMIN_EMAIL=
PGADMIN_PASSWORD=
PGADMIN_PORT=5050


# -------------------------------------------------------------
# Rate Limiting (Istege bagli — varsayilanlar yeterli)
# -------------------------------------------------------------
RATE_LIMIT_PERMIT=100
RATE_LIMIT_WINDOW=60
