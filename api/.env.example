# =============================================================
# LearnLanguage API — Ortam Değişkenleri Şablonu
# =============================================================
# Bu dosyayı kopyalayıp ".env" olarak kaydedin ve gerçek
# değerlerle doldurun:
#
#   cp .env.example .env
#
# UYARI: .env dosyasını ASLA Git'e commit etmeyin.
# =============================================================

# Sunucu portu
PORT=5001

# PostgreSQL bağlantı dizesi
# Örn: postgresql://kullanici:sifre@localhost:5432/veritabani
DATABASE_URL=

# JWT imzalama anahtarı (uzun, rastgele bir dize üretin)
JWT_SECRET=

# -------------------------------------------------------------
# Firebase Admin SDK (Sunucu tarafı)
# Firebase Konsol -> Proje Ayarlari -> Hizmet Hesaplari
# -------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Tek satir halinde, \n kacis karakterleriyle yapistirin
FIREBASE_PRIVATE_KEY=

# -------------------------------------------------------------
# Gemini API
# Google AI Studio -> https://aistudio.google.com/app/apikey
# -------------------------------------------------------------
GEMINI_API_KEY=
